# Server Configuration Example
# Copy this to .env in the server directory

# Port (default 3001 if not specified)
PORT=3001

# Database URL (MongoDB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# Frontend URL (for CORS in production)
FRONTEND_URL=https://your-frontend-url.onrender.com

# Better Auth Configuration
BETTER_AUTH_SECRET=your_secret_key_min_32_chars_long
BETTER_AUTH_URL=https://prepnova.onrender.com

# Email Configuration (for password reset, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="PrepNova" <noreply@prepnova.com>

# Optional: OpenAI API Key (if using AI features)
OPENAI_API_KEY=your-openai-api-key
